use std::os::raw::c_char;
use std::ffi::{CStr, CString};

/// SAFELY FREE RUST-ALLOCATED STRINGS FROM SWIFT
/// This is the required CTO directive to prevent memory leaks across the FFI boundary.
#[no_mangle]
pub unsafe extern "C" fn rust_bridge_idevice_free_string(s: *mut c_char) {
    if s.is_null() { return; }
    let _ = CString::from_raw(s); // Re-take ownership and drop it, freeing the memory.
}

